{
  "name": "FLYKUP",
  "version": "1.0.4",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:fast": "cd android && gradlew assembleDevDebug -PdevBuild --parallel --build-cache --max-workers=4 && cd ..",
    "android:fast:win": "set NODE_OPTIONS=--max-old-space-size=4096 && cd android && gradlew.bat assembleDevDebug -PdevBuild --parallel --build-cache --max-workers=4 && cd ..",
    "android:fast:win:safe": "cd android && build-fast-windows.bat && cd ..",
    "android:super-fast": "set NODE_OPTIONS=--max-old-space-size=4096 && cd android && gradlew.bat assembleDevDebug -PdevBuild -PreactNativeArchitectures=arm64-v8a --parallel --build-cache --max-workers=4 --exclude-task lint && cd ..",
    "android:dev": "react-native run-android --variant=devDebug",
    "android:prod": "react-native run-android --variant=prodRelease",
    "android:clean": "cd android && gradlew clean && cd ..",
    "android:clean:win": "cd android && gradlew.bat clean && cd ..",
    "android:clean-cache": "cd android && gradlew cleanBuildCache && cd ..",
    "android:clean-cache:win": "cd android && gradlew.bat cleanBuildCache && cd ..",
    "android:profile": "cd android && gradlew assembleDevDebug --profile --scan && cd ..",
    "android:profile:win": "cd android && gradlew.bat assembleDevDebug --profile --scan && cd ..",
    "android:build-status": "cd android && gradlew showBuildStatus && cd ..",
    "android:build-status:win": "cd android && gradlew.bat showBuildStatus && cd ..",
    "android:install-dev": "cd android && gradlew installDevDebug -PdevBuild && cd ..",
    "android:install-dev:win": "cd android && gradlew.bat installDevDebug -PdevBuild && cd ..",
    "android:bundle-release": "cd android && gradlew bundleProdRelease && cd ..",
    "android:bundle-release:win": "cd android && gradlew.bat bundleProdRelease && cd ..",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "test": "jest",
    "console:cleanup:dry": "node scripts/cleanup-console-logs.js --dry-run",
    "console:cleanup": "node scripts/cleanup-console-logs.js"
  },
